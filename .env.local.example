# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stripe (프론트엔드 — pk_test_ 로 시작)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_

# Firebase Function URL (배포 후 실제 URL로 교체)
# 로컬: http://localhost:5001/{projectId}/asia-northeast1/createCheckout
# 배포: https://asia-northeast1-{projectId}.cloudfunctions.net/createCheckout
VITE_FUNCTION_URL=http://localhost:5001/YOUR_PROJECT_ID/asia-northeast1/createCheckout

# Firebase Functions (서버 사이드 — .env 에만, git 제외 필수)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
